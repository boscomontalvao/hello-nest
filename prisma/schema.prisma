generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  name     String?
  nickname String?

  @@map("users")
}

model Endereco {
  id     Int    @id @default(autoincrement())
  rua    String
  numero Int
  
  @@map("endereco")
}
